class Solution {
    public boolean isPalindrome(int n) {
        int sum=0;
        int r=0;
        int a=n;
        while(n>0){
            r=n%10;
            sum=(sum*10)+r;
            n=n/10;
           
        }
        if(sum==a){
            return true;
        }
        else{
            return false;
        }
        
    }
}
